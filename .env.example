# PostgreSQL Database Configuration
# 이 변수들은 docker-compose 내부에서 DB_NAME/DB_USERNAME/DB_PASSWORD로 변환됨
# (앱 로그에서 DB_PASSWORD를 보더라도 .env에는 POSTGRES_PASSWORD로 설정해야 함)
POSTGRES_DB=webmonitor
POSTGRES_USER=webmonitor
# Required: 미설정 시 'webmonitor' 폴백이 무음 적용되어 보안 취약
POSTGRES_PASSWORD=your-strong-password-here

# Discord Bot Configuration
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_BOT_ENABLED=false

# API Security
API_SECURITY_ENABLED=true
API_KEY=your-secret-api-key-here

# Monitoring Configuration (optional - defaults are provided)
#MONITOR_RATE_LIMIT_MIN_DELAY_MS=2000
#MONITOR_RATE_LIMIT_MAX_DELAY_MS=5000
#MONITOR_FAILURE_ALERT_THRESHOLD=5
#MONITOR_RESTOCK_ALERT_COOLDOWN_MINUTES=60

# Alert Cleanup (optional - defaults are provided)
#ALERT_CLEANUP_ENABLED=true
#ALERT_CLEANUP_DAYS=30
